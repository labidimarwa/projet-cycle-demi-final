<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- ══════════════════════════════════════════════════
       CONSOLE  — dev / default
  ═══════════════════════════════════════════════════ -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- ══════════════════════════════════════════════════
       APPLICATION LOG  (rolling daily, 30 days)
  ═══════════════════════════════════════════════════ -->
  <appender name="APP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>logs/application.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>logs/application.%d{yyyy-MM-dd}.log</fileNamePattern>
      <maxHistory>30</maxHistory>
      <totalSizeCap>500MB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- ══════════════════════════════════════════════════
       SECURITY AUDIT LOG  — all attack attempts
       Format: timestamp | EVENT_TYPE | ip | url | detail
  ═══════════════════════════════════════════════════ -->
  <appender name="SECURITY_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>logs/security-audit.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>logs/security-audit.%d{yyyy-MM-dd}.log</fileNamePattern>
      <maxHistory>90</maxHistory><!-- 3 months retention for forensics -->
      <totalSizeCap>1GB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} | %-8level | %msg%n</pattern>
    </encoder>
  </appender>

  <!-- ══════════════════════════════════════════════════
       SECURITY_AUDIT named logger
       → writes to BOTH security file and console
       additivity=false  prevents double-logging on root
  ═══════════════════════════════════════════════════ -->
  <logger name="SECURITY_AUDIT" level="INFO" additivity="false">
    <appender-ref ref="SECURITY_FILE"/>
    <appender-ref ref="CONSOLE"/>
  </logger>

  <!-- Application packages -->
  <logger name="com.nexgenai" level="DEBUG" additivity="false">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="APP_FILE"/>
  </logger>

  <!-- Reduce Spring noise -->
  <logger name="org.springframework.security" level="INFO"/>
  <logger name="org.hibernate.SQL"             level="WARN"/>

  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="APP_FILE"/>
  </root>

</configuration>
