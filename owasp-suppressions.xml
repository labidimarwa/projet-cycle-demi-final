    <!-- H2 is test-scope only; not deployed to production -->
    <suppress>
        <notes>H2 database is test-scope only, not reachable in production</notes>
        <gav regex="true">^com\.h2database:h2:.*$</gav>
        <cvssBelow>10</cvssBelow>
    </suppress>

</suppressions>
